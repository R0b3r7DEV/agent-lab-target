# ==========================================================================
#  agent-lab-target - variables de entorno (SOLO PLACEHOLDERS)
# --------------------------------------------------------------------------
#  ENTORNO DELIBERADAMENTE VULNERABLE - SOLO USO LOCAL / RED AISLADA.
#  Los secretos reales (ANTHROPIC_API_KEY) van en .env.local, que esta en
#  .gitignore y NUNCA se commitea. Este fichero solo lleva placeholders.
# ==========================================================================

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=lab_only_change_me_not_a_real_secret
###< symfony/framework-bundle ###

###> laboratorio: nivel de defensa ###
# 0 = sin defensa (baseline) | 1 = separacion datos/instrucciones
# 2 = minimo privilegio + HITL | 3 = filtrado de salida + egress allowlist
#
# LAB_LEVEL NO se declara aqui a proposito (ver ADR 11): un placeholder en .env
# aterriza en $_ENV y ENSOMBRECE la env real del `docker compose` (getenv()).
# Se resuelve en RUNTIME via el procesador `default:` (por defecto 0), lo aporta
# el compose por entorno, y se sobreescribe por peticion con la cabecera
# X-Lab-Level (solo-lab). Para forzar un nivel en local: `LAB_LEVEL=2 php -S ...`.
#
# Politica del humano simulado para acciones sensibles del Nivel 2: deny | allow
LAB_CONFIRM_POLICY=deny
###< laboratorio: nivel de defensa ###

###> laboratorio: cliente Anthropic ###
# La API key vive SOLO en el backend, en .env.local. Jamas en frontend ni logs.
ANTHROPIC_API_KEY=
# Modelo pequeno por defecto: da ASR alto en el baseline (Nivel 0), haciendo
# visible el delta de cada capa de defensa. Configurable por entorno.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Temperature EXPLICITA y documentada: si dependiera del default de la API las
# corridas dejarian de ser comparables. 1.0 da variacion natural entre los N
# intentos por payload (el ASR es probabilistico).
ANTHROPIC_TEMPERATURE=1.0
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
###< laboratorio: cliente Anthropic ###

###> laboratorio: agente ###
# Limite de iteraciones del bucle de tool use (evita bucles infinitos).
AGENT_MAX_ITERATIONS=8
###< laboratorio: agente ###

###> doctrine/doctrine-bundle ###
# Se activa en la Fase 2. Placeholder para docker compose.
DATABASE_URL="postgresql://app:app@database:5432/lab?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###
